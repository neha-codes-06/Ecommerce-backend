<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My orders</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
<body class="p-3 mb-2 bg-danger-subtle text-danger-emphasis">
    <h1>My orders</h1>
    <a  class="link-danger link-offset-2 link-underline-opacity-25 link-underline-opacity-100-hover"href="/cart">Back to cart</a>
<% if (orders.length===0) { %>
    <h3>No orders found</h3>
 
<% } else{%>
    <% orders.forEach(order => { %>
        
        <hr>

        <h3>ORDER ID:<%=order._id  %></h3>
        <p>TOTAL AMOUNT:<%= order.totalAmount %></p>
        <p>STATUS:<%= order.status %></p>
        <% if (order.status==="Pending") { %>

            <form action="/pay-now/<%= order._id %>"method="POST">
         <button type="submit">Pay Now</button>
        </form>
<br>
        <form action="/cancel-order/<%= order._id %>"method="POST">
         <button type="submit">Cancel Order</button>
        </form>
     
    <% }else if(order.status==="Paid") {%>
        



        <%}else{%>

        <%}%>
    
        <h4>Products:</h4>
        <ul>
            <% order.items.forEach(item => { %>
                <li>
                    <strong><%= item.product.name %></strong>
                    Price:<%= item.product.price %>
                    Quantity:<%= item.quantity %>
                    </li>
             
            <% }) %>
            </ul>
     
    <% }) %>


    <%}%>

 
</body>
</html>