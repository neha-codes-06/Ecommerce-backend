<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">

</head>
<body>
  
 <nav class="navbar" style="background-color: #e3f2fd;" data-bs-theme="light">



    <h1>All Products</h1>
<form action="/products" method="GET">
    <input type="text"name="search"placeholder="Search Product" value="<%= search||"" %>">
  <select name="category">
    <option value="">All</option>
            <option value="Mobile">Mobile
                </option>
                <option value="Laptop">Laptop
                </option>
                <option value="Accessory">Accessory
                </option>


        </select>

        <select name="sort">
    <option value="">Default</option>
            <option value="low">Price low to high
                </option>
                <option value="high">Price high to low
                </option>
                


        </select>

    <button type="submit">Search</button>
    <br><br>
    </form>

    
  <form action="/auth/logout" method="POST">
    <button type="submit" class="btn btn-danger">Logout</button>

  </form>
 </nav>
  <br><br>
<div style="display: flex;justify-content:space-between;align-items:center;flex-wrap:wrap; gap:20px">
    <% products.forEach(product=> { %>
            <div class="card" style="width: 18rem; min-height:100px;">
  <img src="/uploads/<%= product.image %>" class="card-img-top"style="height:150px; object-fit:cover;" alt="<%= product.name %>"width="150">
  <div class="card-body">
    <h5 class="card-title"><a href="/products/<%= product._id %>">
                <%= product.name %>
            </a></h5>
    <p class="card-text">Price:<%=product.price%></p>
    <p class="card-text">Description:<%=product.description%></p>
   
<form action="/cart/add/<%= product._id %>" method="POST">
  <button type="submit">Add To Cart</button>
</form>
     
  </div>
</div>

<br><br>
    <% }) %>
</div>

<br><br>
<nav aria-label="Page navigation example">
  <ul class="pagination justify-content-center">
    <li class="page-item ">
    <% if (page>1) { %>
      <a class="page-link" href="/products?search=<%=search%>&category=<%=category%>&sort=<%=sort%>&page=<%=page - 1 %>" >Previous</a>
    <% } %>
    </li>
    <li class="page-item">
      <% for( let i= 1; i <=totalPages; i++ ) { %>
      <a class="page-link" href="/products?search=<%=search%>&category=<%=category%>&sort=<%=sort%>&page=<%= i %>"><%= i %></a></li>
      <% } %>

    <li class="page-item">
       <% if (page<totalPages) { %>
      <a class="page-link" href="/products?search=<%=search%>&category=<%=category%>&sort=<%=sort%>&page=<%=page+1 %>">Next</a>
      <% } %>
    </li>
  </ul>
</nav>



</body>
</html>